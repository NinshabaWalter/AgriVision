# AgriVision Enhanced API Gateway Environment Configuration
# Copy this file to .env and update with your actual API keys and configuration

# Server Configuration
NODE_ENV=development
PORT=3000

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production-make-it-long-and-random

# Database (for production)
DATABASE_URL=sqlite:./agrivision.db
# DATABASE_URL=postgresql://username:password@localhost:5432/agrivision
# DATABASE_URL=mongodb://localhost:27017/agrivision

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# M-Pesa Integration (Safaricom Daraja API)
MPESA_ENV=sandbox
# MPESA_ENV=production
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
# Place your firebase-service-account.json file in the root directory

# Agora (Video/Voice Communication)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# AI/ML Services
HUGGINGFACE_API_KEY=your_huggingface_api_token
OPENAI_API_KEY=your_openai_api_key

# Market Data APIs
ALPHA_VANTAGE_KEY=your_alpha_vantage_api_key

# Email Service (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Cloud Storage (Optional - for image uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=agrivision-uploads

# Redis (Optional - for advanced caching)
REDIS_URL=redis://localhost:6379

# Monitoring and Analytics
SENTRY_DSN=your_sentry_dsn_for_error_tracking
GOOGLE_ANALYTICS_ID=your_google_analytics_id

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=10

# CORS Configuration (Production)
ALLOWED_ORIGINS=https://agrivision.com,https://app.agrivision.com

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_PAYMENT_FEATURES=true
ENABLE_COMMUNITY_FEATURES=true
ENABLE_ANALYTICS=true

# East Africa Specific
DEFAULT_COUNTRY=kenya
DEFAULT_CURRENCY=KES
DEFAULT_LANGUAGE=english
SUPPORTED_LANGUAGES=english,swahili

# Weather API Configuration
WEATHER_CACHE_TTL=300
WEATHER_API_TIMEOUT=5000

# Market Data Configuration
MARKET_DATA_CACHE_TTL=600
MARKET_API_TIMEOUT=3000

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Notification Configuration
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=false

# Development/Testing
MOCK_EXTERNAL_APIS=false
ENABLE_API_DOCS=true
ENABLE_METRICS_ENDPOINT=true