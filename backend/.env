# Database Configuration (using SQLite for development)
DATABASE_URL=sqlite:///./agricultural_platform.db
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# External API Keys (optional for basic testing)
OPENWEATHER_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
FIREBASE_SERVER_KEY=

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@agriplatform.com

# File Storage
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx

# ML Models
ML_MODEL_PATH=./models
DISEASE_DETECTION_MODEL=disease_detection.tflite
DISEASE_LABELS_FILE=disease_labels.txt

# Monitoring & Logging
SENTRY_DSN=
LOG_LEVEL=INFO
ENABLE_METRICS=true

# Development Settings
DEBUG=true
TESTING=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

# Production Settings
ENVIRONMENT=development
DOMAIN=localhost
SSL_ENABLED=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Cache Settings
CACHE_TTL_SECONDS=3600
WEATHER_CACHE_TTL=1800
MARKET_CACHE_TTL=900

# Mobile App Configuration
MOBILE_APP_VERSION=1.0.0
FORCE_UPDATE_VERSION=1.0.0
MAINTENANCE_MODE=false